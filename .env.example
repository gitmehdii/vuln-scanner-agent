# ── Option 1: OpenRouter (DeepSeek V3/R1) ──────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Option 2: OpenAI ────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here

# ── Option 3: Local model (Ollama, LM Studio, llama.cpp, vLLM, ...) ────────
# Any server that exposes an OpenAI-compatible /v1 API works.
#
# Ollama (http://localhost:11434):
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   LOCAL_MODEL=qwen2.5:14b
#
# LM Studio (http://localhost:1234):
#   OPENAI_BASE_URL=http://localhost:1234/v1
#   LOCAL_MODEL=your-loaded-model
#
# Separate reasoning model (optional — defaults to LOCAL_MODEL if not set):
#   LOCAL_REASONING_MODEL=deepseek-r1:8b
#
# If your local server requires an API key:
#   OPENAI_API_KEY=anything

# ── SAST (optional) ──────────────────────────────────────────────────────────
# Community rules are enabled by default (requires internet on first run, then cached).
# Set to false for offline / CI environments.
# SEMGREP_COMMUNITY=false

# ── GitHub (optional) ────────────────────────────────────────────────────────
# Required only for --issue flag (creates a GitHub issue with the findings)
# GITHUB_TOKEN=ghp_your-token-here
